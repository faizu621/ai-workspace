# Dependencies
**/node_modules/
**/jspm_packages/
**/pnpm-lock.yaml

# Next.js build output
**/.next/
**/out/

# Maven build output
**/target/
**/*.class

# Environment files (sensitive credentials)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# IDEs and editors configuration
**/.idea/
**/*.iml
**/.vscode/
**/.settings/
**/.project
**/.classpath
**/bin/
**/.factorypath

# OS files
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
